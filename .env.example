# .env.example — Copy this to .env and fill in your values. Never commit .env.

# PostgreSQL connection string from Supabase:
# Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Cloudinary image storage credentials (free account from cloudinary.com)
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Path to your Firebase service account JSON key file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=secrets/firebase-sa.json

# The URL where your React frontend is hosted (Firebase Hosting URL or localhost for dev)
# Used for CORS allow-origin on the FastAPI backend
FRONTEND_URL=https://your-project-id.web.app

